{
  "expo": {
    "name": "Impostor Fútbol",
    "slug": "impostor-futbol",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "impostor",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b0f0e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doonbro.impostorfutbol",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Usamos el micrófono para la sala de audio multijugador."
      }
    },
    "android": {
      "package": "com.doonbro.impostorfutbol",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "impostor-futbol.vercel.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "./plugins/withKotlinVersionCatalogFix"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c462bae9-8a4c-4677-98d5-13d00f4b07e5"
      }
    },
    "owner": "doonstein"
  }
}
