{
  "name": "@impostor/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --clear",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "eas:dev:android": "eas build --profile development --platform android",
    "eas:dev:ios": "eas build --profile development --platform ios",
    "eas:preview:android": "eas build --profile preview --platform android",
    "eas:preview:ios": "eas build --profile preview --platform ios",
    "eas:prod": "eas build --profile production --platform all",
    "eas:submit": "eas submit --profile production",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/metro-runtime": "~56.0.0",
    "@impostor/backend": "workspace:*",
    "@impostor/core": "workspace:*",
    "@impostor/data": "workspace:*",
    "@impostor/ui": "workspace:*",
    "@livekit/react-native": "^2.11.1",
    "@livekit/react-native-webrtc": "^144.1.1",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "convex": "^1.17.4",
    "expo": "~56.0.0",
    "expo-build-properties": "~56.0.0",
    "expo-clipboard": "~56.0.0",
    "expo-constants": "~56.0.0",
    "expo-font": "~56.0.0",
    "expo-haptics": "~56.0.0",
    "expo-linking": "~56.0.0",
    "expo-router": "~56.0.0",
    "expo-status-bar": "~56.0.0",
    "livekit-client": "^2.19.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.0.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.5.0",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "~15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.10.0",
    "tailwind-merge": "^3.6.0",
    "uniwind": "^1.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.6.3"
  }
}
