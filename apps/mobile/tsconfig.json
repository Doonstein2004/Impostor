{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@impostor/core": ["../../packages/core/src"],
      "@impostor/data": ["../../packages/data/src"],
      "@impostor/ui": ["../../packages/ui/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/uniwind-types.d.ts"
  ],
  "exclude": ["node_modules"]
}
