{
  "name": "impostor-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "mobile": "pnpm --filter @impostor/mobile",
    "backend": "pnpm --filter @impostor/backend",
    "desktop": "pnpm --filter @impostor/desktop",
    "desktop:dev": "pnpm --filter @impostor/desktop dev",
    "desktop:build": "pnpm --filter @impostor/desktop build",
    "convex:dev": "pnpm --filter @impostor/backend dev",
    "data:generate": "pnpm --filter @impostor/data generate",
    "sync": "node scripts/sync-workspace.js",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.6.3",
    "prettier": "^3.4.2"
  }
}
